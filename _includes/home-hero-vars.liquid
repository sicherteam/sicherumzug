{% assign hero_mobile = site.images.hero_mobile | default: site.images.hero %}
{% assign hero_desktop = site.images.hero_desktop | default: hero_mobile %}
{% assign hero_mobile_variants = site.images.hero_mobile_srcset %}
{% assign hero_desktop_variants = site.images.hero_desktop_srcset %}
{% assign hero_dimensions = site.images.hero_dimensions.desktop %}
{% assign hero_width = hero_dimensions.width | default: 1632 %}
{% assign hero_height = hero_dimensions.height | default: 640 %}
{% assign hero_image_sizes = "(min-width: 1280px) 1440px, 100vw" %}
{% assign hero_mobile_sizes = "100vw" %}
{% capture hero_mobile_srcset -%}
  {% if hero_mobile_variants %}
    {% for variant in hero_mobile_variants -%}
      {{ variant.url | relative_url }} {{ variant.descriptor }}{% unless forloop.last %}, {% endunless %}
    {% endfor -%}
  {% else %}
    {{ hero_mobile | relative_url }} {{ hero_width }}w
  {% endif -%}
{%- endcapture %}
{% capture hero_desktop_srcset -%}
  {% if hero_desktop_variants %}
    {% for variant in hero_desktop_variants -%}
      {{ variant.url | relative_url }} {{ variant.descriptor }}{% unless forloop.last %}, {% endunless %}
    {% endfor -%}
  {% else %}
    {{ hero_desktop | relative_url }} {{ hero_width }}w
  {% endif -%}
{%- endcapture %}
{% assign hero_mobile_preload_href = hero_mobile %}
{% if hero_mobile_variants and hero_mobile_variants.size > 0 %}
  {% assign hero_mobile_candidate = hero_mobile_variants | last %}
  {% if hero_mobile_candidate.url %}
    {% assign hero_mobile_preload_href = hero_mobile_candidate.url %}
  {% endif %}
  {% for variant in hero_mobile_variants %}
    {% assign descriptor = variant.descriptor | downcase %}
    {% if descriptor contains '800' %}
      {% assign hero_mobile_preload_href = variant.url %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}
{% assign hero_desktop_preload_href = hero_desktop %}
{% if hero_desktop_variants and hero_desktop_variants.size > 0 %}
  {% assign hero_desktop_candidate = hero_desktop_variants | last %}
  {% if hero_desktop_candidate.url %}
    {% assign hero_desktop_preload_href = hero_desktop_candidate.url %}
  {% endif %}
  {% for variant in hero_desktop_variants %}
    {% assign descriptor = variant.descriptor | downcase %}
    {% if descriptor contains '1440' %}
      {% assign hero_desktop_preload_href = variant.url %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}
